{
  "name": "@openplaw/openplaw",
  "version": "0.2.5",
  "description": "Feishu/DingTalk bot management platform with visible cross-bot routing, custom agent auto-discovery, runtime schema patching, and autonomous execution - built on opencode + omo",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "openplaw": "dist/cli/index.js"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "postinstall": "node dist/scripts/postinstall.js || true",
    "dev": "npm run build && npx tsx --watch src/cli/index.ts start",
    "dev:watch": "tsc --watch",
    "test": "vitest run",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "web:build": "cd web && npm run build",
    "web:dev": "cd web && npm run dev"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@larksuiteoapi/node-sdk": "^1.63.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@opencode-ai/plugin": "^1.14.48",
    "@opencode-ai/sdk": "^1.14.48",
    "@openplaw/comment-checker": "0.7.0",
    "hono": "^4.7.0",
    "oh-my-opencode": "^4.1.2",
    "opencode-ai": "^1.15.0",
    "undici": "^7.25.0"
  },
  "overrides": {
    "@code-yeongyu/comment-checker": "npm:@openplaw/comment-checker@0.7.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.19.19",
    "eslint": "^9.0.0",
    "prettier": "^3.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.6.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^2.0.0"
  },
  "files": [
    "dist/",
    "web/dist/",
    "scripts/",
    "extensions/",
    "agents/",
    "README.md"
  ],
  "keywords": [
    "feishu",
    "dingtalk",
    "bot",
    "agent",
    "opencode",
    "omo",
    "lark"
  ],
  "license": "MIT"
}
